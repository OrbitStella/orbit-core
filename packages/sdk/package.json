{
  "name": "@orbit-core/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for interacting with Stellar/Soroban",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./logger": {
      "import": "./dist/logger.js",
      "types": "./dist/logger.d.ts"
    },
    "./errors": {
      "import": "./dist/errors.js",
      "types": "./dist/errors.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^11.0.0"
  },
  "devDependencies": {
    "typescript": "workspace:*",
    "@types/node": "^20.0.0"
  }
}
